{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Audion",
  "version": "0.1.3",
  "identifier": "com.sagami121.audion",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Audion",
        "width": 1000,
        "height": 660,
        "minWidth": 760,
        "minHeight": 520,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "audion"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "shortDescription": "Audion Music Player",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": [
          "en-US",
          "ja-JP",
          "ko-KR",
          "zh-CN"
        ]
      },
      "nsis": {
        "languages": [
          "English",
          "Japanese",
          "Korean",
          "SimpChinese"
        ],
        "displayLanguageSelector": true
      }
    },
    "fileAssociations": [
      {
        "ext": [
          "mp3",
          "wav",
          "flac",
          "m4a",
          "ogg",
          "aac",
          "opus",
          "aiff",
          "wma"
        ],
        "name": "Audio File",
        "description": "Audion Audio File"
      }
    ]
  }
}
